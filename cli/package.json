{
  "name": "live-translate",
  "version": "0.1.0",
  "description": "Real-time English ↔ Mandarin speech translator. Local-first, cloud-optional.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "live-translate": "dist/index.js",
    "live-translate-mcp": "dist/mcp.js"
  },
  "files": [
    "dist/"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/index.js dist/mcp.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.3.0",
    "@inquirer/prompts": "^8.4.3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "onnxruntime-node": "^1.20.0",
    "ora": "^8.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
